# ==============================================
# AgentDNS环境配置文件
# 该文件覆盖config.py中的默认值
# ==============================================

# 数据库配置
DATABASE_URL=postgresql://agentdns:your_password_here@localhost:5432/agentdns  # PostgreSQL数据库连接URL
REDIS_URL=redis://localhost:6379  # Redis缓存连接URL

# Milvus向量数据库配置
MILVUS_HOST=localhost  # Milvus服务主机地址
MILVUS_PORT=19530  # Milvus服务端口
MILVUS_COLLECTION_NAME=agentdns_services  # Milvus中存储服务向量的集合名称
MILVUS_DIMENSION=2560  # 向量维度，保持2560维度以兼容现有向量

# JWT安全配置（⚠️ 生产环境中必须修改）
SECRET_KEY=your-secret-key-here  # JWT密钥，用于签名和验证令牌，必须使用强密钥
ALGORITHM=HS256  # JWT加密算法
ACCESS_TOKEN_EXPIRE_MINUTES=30  # 访问令牌过期时间（分钟）

# OpenAI API配置（⚠️ 生产环境中必须修改）
OPENAI_API_KEY=your-openai-api-key  # OpenAI API密钥，用于向量嵌入
OPENAI_BASE_URL=https://api.openai.com/v1  # OpenAI API基础URL
OPENAI_EMBEDDING_MODEL=text-embedding-3-large  # 使用的嵌入模型
OPENAI_MAX_TOKENS=8000  # 最大令牌数限制

# 加密配置（⚠️ 请使用命令生成真实密钥）
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key  # 加密密钥，用于加密敏感数据

# 环境配置
ENVIRONMENT=development  # 运行环境（development/production）
DEBUG=true  # 是否开启调试模式